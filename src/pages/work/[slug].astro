---
import Layout from '../../layouts/Layout.astro';
import {
  getAllFilters,
  getFilterWithStudies,
  type FilterConfig,
  type CaseStudy,
} from '../../data/cv-tailor';

export function getStaticPaths() {
  const filters = getAllFilters();
  return filters.map((filter) => ({
    params: { slug: filter.slug },
    props: { filter },
  }));
}

const { filter } = Astro.props;
const data = getFilterWithStudies(filter.slug);

if (!data) {
  return Astro.redirect('/404');
}

const { studies } = data;
const featuredStudies = studies.filter(s => s.visibility === 'featured');
const browseableStudies = studies.filter(s => s.visibility === 'browseable');
const hiddenStudies = studies.filter(s => s.visibility === 'hidden');

// Derive page metadata from filter + first study context
const pageTitle = `${filter.title} — Tobias Treppmann`;
const pageDescription = filter.subtitle || `Selected work for ${filter.slug}`;
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="hero">
    <div class="container">
      <p class="hero-tagline">Portfolio</p>
      <h1 class="animated-headline" id="animated-title">{filter.title}</h1>

<script>
  const fonts = ['Redaction 20', 'Redaction 35', 'Redaction 50', 'Redaction 70'];
  const title = document.getElementById('animated-title');
  if (title) {
    const text = title.textContent || '';
    title.innerHTML = text.split('').map((char, i) =>
      char === ' ' ? ' ' : `<span class="letter" data-index="${i}">${char}</span>`
    ).join('');
    const letters = title.querySelectorAll('.letter');
    letters.forEach((letter) => {
      let currentFontIndex = Math.floor(Math.random() * fonts.length);
      letter.style.fontFamily = `"${fonts[currentFontIndex]}", Georgia, serif`;
      const animate = () => {
        const newIndex = Math.floor(Math.random() * fonts.length);
        currentFontIndex = newIndex;
        letter.style.fontFamily = `"${fonts[currentFontIndex]}", Georgia, serif`;
        const nextInterval = 1500 + Math.random() * 2500;
        setTimeout(animate, nextInterval);
      };
      const delay = Math.random() * 5000;
      setTimeout(animate, delay);
    });
  }
</script>
      {filter.subtitle && (
        <p class="hero-description">{filter.subtitle}</p>
      )}
    </div>
  </section>

  <!-- Featured Case Studies -->
  {featuredStudies.length > 0 && (
    <section class="section" id="case-studies">
      <div class="container">
        <div class="section-header">
          <h2>Case Studies</h2>
        </div>
        <div class="case-studies-grid">
          {featuredStudies.map((study: any) => {
            const heroSection = study.sections?.find((s: any) => s.type === 'hero');
            const outcomeSection = study.sections?.find((s: any) => s.type === 'outcome');
            return (
              <div class="case-study-card-full">
                <div class="cs-header">
                  <div class="cs-meta">
                    <span class="cs-company">{study.company}</span>
                    <span class="cs-duration">{study.duration}</span>
                    <span class="cs-role">{study.role}</span>
                  </div>
                  <h3>{heroSection?.headline || study.title}</h3>
                  {study.subtitle && <p class="subtitle">{study.subtitle}</p>}
                </div>

                {(heroSection?.subtext || outcomeSection?.content) && (
                  <p class="cs-description">
                    {heroSection?.subtext || outcomeSection?.content?.substring(0, 200) + '...'}
                  </p>
                )}

                {/* Metrics */}
                {outcomeSection?.metrics && outcomeSection.metrics.length > 0 && (
                  <div class="cs-metrics">
                    {outcomeSection.metrics.map((m: any) => (
                      <div class="metric">
                        <span class="metric-label">{m.label}</span>
                        {m.value && <span class="metric-value">{m.value}</span>}
                        {m.before && m.after && (
                          <span class="metric-change">{m.before} → {m.after}</span>
                        )}
                      </div>
                    ))}
                  </div>
                )}

                {/* Tags */}
                <div class="cs-tags">
                  {study.tags.slice(0, 5).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>

                {/* Format indicator */}
                {study.format_override && (
                  <span class="format-badge">{study.format_override}</span>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Browseable Studies (collapsed) -->
  {(browseableStudies.length > 0 || hiddenStudies.length > 0) && (
    <section class="section" id="more-work">
      <div class="container">
        <details class="show-more">
          <summary>{filter.show_all_label || 'Show more work'}</summary>
          <div class="case-studies-grid" style="margin-top: var(--space-lg);">
            {browseableStudies.map((study: any) => {
              const heroSection = study.sections?.find((s: any) => s.type === 'hero');
              return (
                <div class="case-study-card-full browseable">
                  <div class="cs-meta">
                    <span class="cs-company">{study.company}</span>
                    <span class="cs-duration">{study.duration}</span>
                  </div>
                  <h3>{heroSection?.headline || study.title}</h3>
                  {study.subtitle && <p class="subtitle">{study.subtitle}</p>}
                  <div class="cs-tags">
                    {study.tags.slice(0, 4).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </details>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section" id="next-steps">
    <div class="container content">
      <div class="section-header">
        <h2>Let's Talk</h2>
        <p>
          Want the full picture? <a href="/about">Learn more about me</a>, or
          <a href="/">see all case studies</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Full-width case study cards */
  .case-studies-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .case-study-card-full {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-lg) var(--space-xl);
    transition: border-color 0.2s;
  }

  .case-study-card-full:hover {
    border-color: var(--color-accent);
  }

  .cs-header {
    margin-bottom: var(--space-md);
  }

  .cs-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .cs-company {
    font-weight: 600;
    color: var(--color-accent);
  }

  .cs-role {
    font-style: italic;
  }

  .cs-header h3 {
    font-size: 1.4rem;
    margin-bottom: var(--space-xs);
  }

  .cs-description {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  /* Metrics */
  .cs-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    padding: var(--space-md);
    background: var(--color-bg);
    border-radius: 8px;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .metric-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .metric-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .metric-change {
    font-size: 0.85rem;
    color: var(--color-text);
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .format-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 2px 10px;
    border-radius: 100px;
    margin-top: var(--space-sm);
  }

  /* Show more toggle */
  .show-more {
    border: none;
    cursor: pointer;
  }

  .show-more summary {
    font-size: 1rem;
    color: var(--color-accent);
    font-weight: 500;
    padding: var(--space-md) 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .show-more summary::before {
    content: '+';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-accent-light);
    font-weight: 600;
  }

  .show-more[open] summary::before {
    content: '−';
  }

  .browseable {
    opacity: 0.9;
  }

  #next-steps p {
    font-size: 1.05rem;
  }
</style>
