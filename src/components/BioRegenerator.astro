---
/**
 * BioRegenerator — three-dial control that picks lens × length × model
 * and live-generates the bio via the treppmann-bio-api endpoint.
 *
 * - First paint: uses a pre-generated fallback variant from
 *   src/data/bio-variants.json (so the page works without JS and during
 *   API outages).
 * - On any dial change: fetches POST /bio with the current params,
 *   shows a loading state, replaces the text with the model's output.
 *   On error: falls back to the pre-generated text for that lens+length
 *   (independent of model — model variation is the API's value-add).
 */
import bioData from '../data/bio-variants.json';

const { lenses, lengths, models, default: defaultVariant, variants, api_url } =
  bioData as any;
const defaultText = variants[defaultVariant.lens][defaultVariant.length];
const variantsJson = JSON.stringify(variants);
---

<div
  class="bio-regen"
  data-default-lens={defaultVariant.lens}
  data-default-length={defaultVariant.length}
  data-default-model={defaultVariant.model}
  data-api-url={api_url}
>
  <p class="bio-regen__hint">↻ &nbsp;TAP A DIAL — A LIVE MODEL WILL REGENERATE THIS BIO</p>

  <div class="bio-regen__controls" role="group" aria-label="Choose how to read this bio">
    <div class="bio-regen__dial">
      <span class="bio-regen__dial-label">LENS</span>
      <div class="bio-regen__options" role="radiogroup" aria-label="Lens">
        {lenses.map((lens: any) => (
          <button
            type="button"
            class="bio-regen__option"
            data-axis="lens"
            data-value={lens.id}
            data-active={lens.id === defaultVariant.lens ? 'true' : 'false'}
            role="radio"
            aria-checked={lens.id === defaultVariant.lens ? 'true' : 'false'}
          >
            {lens.label}
          </button>
        ))}
      </div>
    </div>

    <div class="bio-regen__dial">
      <span class="bio-regen__dial-label">LENGTH</span>
      <div class="bio-regen__options" role="radiogroup" aria-label="Length">
        {lengths.map((len: any) => (
          <button
            type="button"
            class="bio-regen__option"
            data-axis="length"
            data-value={len.id}
            data-active={len.id === defaultVariant.length ? 'true' : 'false'}
            role="radio"
            aria-checked={len.id === defaultVariant.length ? 'true' : 'false'}
          >
            {len.label}
          </button>
        ))}
      </div>
    </div>

    <div class="bio-regen__dial">
      <span class="bio-regen__dial-label">MODEL</span>
      <div class="bio-regen__options" role="radiogroup" aria-label="Model">
        {models.map((m: any) => (
          <button
            type="button"
            class="bio-regen__option"
            data-axis="model"
            data-value={m.id}
            data-active={m.id === defaultVariant.model ? 'true' : 'false'}
            role="radio"
            aria-checked={m.id === defaultVariant.model ? 'true' : 'false'}
          >
            {m.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <p class="bio-regen__text" aria-live="polite" data-bio-text>
    {defaultText}
  </p>

  <p class="bio-regen__caption" data-bio-caption>
    <span class="bio-regen__caption-dot" aria-hidden="true">●</span>
    <span data-bio-caption-text>Fallback bio shown on first paint &mdash; pick any dial to live-generate.</span>
  </p>
</div>

<script is:inline define:vars={{ variantsJson }}>
  // Static-site safe hydration. No framework runtime.
  (function () {
    const variants = JSON.parse(variantsJson);
    const roots = document.querySelectorAll('.bio-regen');
    roots.forEach((root) => {
      const textEl = root.querySelector('[data-bio-text]');
      const captionEl = root.querySelector('[data-bio-caption-text]');
      if (!textEl || !captionEl) return;

      const apiUrl = root.getAttribute('data-api-url');
      let currentLens = root.getAttribute('data-default-lens');
      let currentLength = root.getAttribute('data-default-length');
      let currentModel = root.getAttribute('data-default-model');

      const buttons = root.querySelectorAll('.bio-regen__option');
      let inFlightToken = 0;

      function setButtonStates(axis, value) {
        buttons.forEach((btn) => {
          if (btn.getAttribute('data-axis') !== axis) return;
          const isActive = btn.getAttribute('data-value') === value;
          btn.setAttribute('data-active', isActive ? 'true' : 'false');
          btn.setAttribute('aria-checked', isActive ? 'true' : 'false');
        });
      }

      function setDisabled(disabled) {
        buttons.forEach((btn) => {
          if (disabled) btn.setAttribute('disabled', 'true');
          else btn.removeAttribute('disabled');
        });
      }

      function setCaption(text, kind) {
        captionEl.textContent = text;
        captionEl.parentElement.setAttribute('data-state', kind);
      }

      async function regenerate() {
        const token = ++inFlightToken;
        const lens = currentLens;
        const length = currentLength;
        const model = currentModel;

        setCaption('Asking ' + model + '…', 'loading');
        textEl.classList.add('bio-regen__text--loading');
        setDisabled(true);

        try {
          const res = await fetch(apiUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ lens: lens, length: length, model: model }),
          });
          if (token !== inFlightToken) return; // a newer click superseded us
          if (!res.ok) {
            const errData = await res.json().catch(() => ({}));
            throw new Error(errData.error || ('HTTP ' + res.status));
          }
          const data = await res.json();
          if (token !== inFlightToken) return;
          textEl.textContent = data.text;
          setCaption(
            'Generated by ' +
              model +
              (data.cached ? ' · cached' : ' · live') +
              ' · ' +
              lens +
              ' lens, ' +
              length +
              ' length',
            'ok'
          );
        } catch (err) {
          if (token !== inFlightToken) return;
          // Fall back to pre-generated text for this lens+length (model
          // dimension doesn't exist in the fallback set; that's by design).
          const fallback = variants[lens] && variants[lens][length];
          if (fallback) textEl.textContent = fallback;
          setCaption(
            'Live generation failed (' +
              (err && err.message ? err.message : 'network error') +
              ') — showing fallback text.',
            'error'
          );
        } finally {
          if (token === inFlightToken) {
            textEl.classList.remove('bio-regen__text--loading');
            setDisabled(false);
          }
        }
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const axis = btn.getAttribute('data-axis');
          const value = btn.getAttribute('data-value');
          if (!axis || !value) return;
          if (axis === 'lens') currentLens = value;
          else if (axis === 'length') currentLength = value;
          else if (axis === 'model') currentModel = value;
          setButtonStates(axis, value);
          regenerate();
        });
      });
    });
  })();
</script>

<style is:global>
  /* ---------------------------------------------------------------- */
  /* BioRegenerator                                                   */
  /* ---------------------------------------------------------------- */

  .bio-regen {
    margin-top: var(--space-md);
  }

  .bio-regen__hint {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
    user-select: none;
  }

  .bio-regen__controls {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: var(--space-md);
    max-width: 50ch;
  }

  .bio-regen__dial {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    column-gap: 0.9rem;
    align-items: baseline;
  }

  .bio-regen__dial-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    user-select: none;
  }

  .bio-regen__options {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.2;
    align-items: baseline;
  }

  .bio-regen__option {
    background: none;
    border: none;
    padding: 0.25rem 0.55rem;
    font: inherit;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: 0;
    transition: color 0.15s ease, opacity 0.15s ease;
    letter-spacing: 0.02em;
    position: relative;
  }

  .bio-regen__option + .bio-regen__option::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.3rem;
    bottom: 0.3rem;
    width: 1px;
    background: var(--color-rule);
  }

  .bio-regen__option:hover,
  .bio-regen__option:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .bio-regen__option[data-active='true'] {
    color: var(--color-accent);
  }

  .bio-regen__option[data-active='true']::after {
    content: '';
    position: absolute;
    left: 0.55rem;
    right: 0.55rem;
    bottom: 0.05rem;
    height: 1px;
    background: var(--color-accent);
  }

  .bio-regen__option[disabled] {
    opacity: 0.5;
    cursor: wait;
  }

  .bio-regen__text {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 50ch;
    margin: 0;
    transition: opacity 0.18s ease;
  }

  .bio-regen__text--loading {
    opacity: 0.4;
  }

  /* Caption shows generation state: loading / ok / error / first-paint. */
  .bio-regen__caption {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0.6rem 0 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    max-width: 50ch;
  }

  .bio-regen__caption-dot {
    color: var(--color-rule);
    font-size: 0.5rem;
    line-height: 1;
    transform: translateY(-0.15rem);
  }

  .bio-regen__caption[data-state='loading'] .bio-regen__caption-dot {
    color: var(--color-accent);
    animation: bio-regen-pulse 1.2s ease-in-out infinite;
  }

  .bio-regen__caption[data-state='ok'] .bio-regen__caption-dot {
    color: var(--color-accent);
  }

  .bio-regen__caption[data-state='error'] .bio-regen__caption-dot {
    color: #b8624c;
  }

  @keyframes bio-regen-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  @media (max-width: 50rem) {
    .bio-regen__dial {
      grid-template-columns: 1fr;
      row-gap: 0.15rem;
      margin-bottom: 0.5rem;
    }
  }
</style>
