---
/**
 * BioRegenerator — three-dial control (Length × Model × Vibe) that
 * live-generates Tobias Treppmann's bio via the treppmann-bio-api
 * endpoint.
 *
 * - First paint: pre-generated fallback variant from bio-variants.json
 *   (works without JS and during API outages).
 * - On any dial change: POST /bio with current params, loading state on
 *   the bio + caption, replace text with the model's output.
 * - On error: fall back to the pre-generated text for the current length;
 *   caption shows reason.
 *
 * Text container is a <div> so the renderer can emit proper <p> children
 * per paragraph (Wikipedia long output uses real paragraph breaks).
 */
import bioData from '../data/bio-variants.json';

const { lengths, models, vibes, default: defaultVariant, variants, api_url } =
  bioData as any;
const defaultText = variants[defaultVariant.length];
const variantsJson = JSON.stringify(variants);
---

<div
  class="bio-regen"
  data-default-length={defaultVariant.length}
  data-default-model={defaultVariant.model}
  data-default-vibe={defaultVariant.vibe}
  data-api-url={api_url}
>
  <div class="bio-regen__text" aria-live="polite" data-bio-text>
    <p>{defaultText}</p>
  </div>

  <div class="bio-regen__controls" role="group" aria-label="Choose how to read this bio">
    <div class="bio-regen__dial">
      <span class="bio-regen__dial-label">LENGTH</span>
      <div class="bio-regen__options" role="radiogroup" aria-label="Length">
        {lengths.map((len: any) => (
          <button
            type="button"
            class="bio-regen__option"
            data-axis="length"
            data-value={len.id}
            data-active={len.id === defaultVariant.length ? 'true' : 'false'}
            role="radio"
            aria-checked={len.id === defaultVariant.length ? 'true' : 'false'}
          >
            {len.label}
          </button>
        ))}
      </div>
    </div>

    <div class="bio-regen__dial">
      <span class="bio-regen__dial-label">MODEL</span>
      <div class="bio-regen__options" role="radiogroup" aria-label="Model">
        {models.map((m: any) => (
          <button
            type="button"
            class="bio-regen__option"
            data-axis="model"
            data-value={m.id}
            data-active={m.id === defaultVariant.model ? 'true' : 'false'}
            role="radio"
            aria-checked={m.id === defaultVariant.model ? 'true' : 'false'}
          >
            {m.label}
          </button>
        ))}
      </div>
    </div>

    <div class="bio-regen__dial">
      <span class="bio-regen__dial-label">VIBE</span>
      <div class="bio-regen__options" role="radiogroup" aria-label="Vibe">
        {vibes.map((v: any) => (
          <button
            type="button"
            class="bio-regen__option"
            data-axis="vibe"
            data-value={v.id}
            data-active={v.id === defaultVariant.vibe ? 'true' : 'false'}
            role="radio"
            aria-checked={v.id === defaultVariant.vibe ? 'true' : 'false'}
          >
            {v.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="bio-regen__action">
    <button type="button" class="bio-regen__generate" data-bio-generate>
      ↻ Regenerate bio
    </button>
  </div>

  <p class="bio-regen__caption" data-bio-caption>
    <span class="bio-regen__caption-dot" aria-hidden="true">●</span>
    <span data-bio-caption-text>Pre-written bio. Set the dials, then hit Regenerate for a live AI version.</span>
  </p>
</div>

<script is:inline define:vars={{ variantsJson }}>
  (function () {
    const variants = JSON.parse(variantsJson);

    // "Resolve sweep": the bio first appears as low-fidelity Redaction noise,
    // then resolves word-by-word into the clean body font, left-to-right —
    // reading as text being generated. Runs on first paint and after every
    // regenerate. Honours prefers-reduced-motion (text shown clean, no anim).
    const REDACT = ['"Redaction 20"', '"Redaction 35"', '"Redaction 50"', '"Redaction 70"'];
    const prefersReduced =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function wrapWords(el) {
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
      const nodes = [];
      while (walker.nextNode()) nodes.push(walker.currentNode);
      const words = [];
      nodes.forEach((node) => {
        const text = node.textContent;
        if (!text || !text.trim()) return;
        const frag = document.createDocumentFragment();
        text.split(/(\s+)/).forEach((part) => {
          if (!part) return;
          if (/^\s+$/.test(part)) {
            frag.appendChild(document.createTextNode(part));
          } else {
            const span = document.createElement('span');
            span.className = 'bio-word';
            span.textContent = part;
            frag.appendChild(span);
            words.push(span);
          }
        });
        node.parentNode.replaceChild(frag, node);
      });
      return words;
    }

    function resolveSweep(el) {
      if (prefersReduced) return;
      const words = wrapWords(el);
      if (!words.length) return;
      // Deliberate, perceptible left-to-right resolve (~2.2s sweep), so it
      // reads as the bio being generated rather than a quick flicker.
      const stagger = Math.max(20, Math.min(60, Math.round(2200 / words.length)));
      words.forEach((w, i) => {
        w.classList.add('bio-word--scrambling');
        w.style.fontFamily = REDACT[0] + ', Georgia, serif';
        let step = 0;
        const tick = () => {
          step += 1;
          if (step < REDACT.length) {
            w.style.fontFamily = REDACT[step] + ', Georgia, serif';
            setTimeout(tick, 95);
          } else {
            w.style.fontFamily = '';
            w.classList.remove('bio-word--scrambling');
            w.classList.add('bio-word--resolved');
          }
        };
        setTimeout(tick, i * stagger);
      });
    }

    const roots = document.querySelectorAll('.bio-regen');
    roots.forEach((root) => {
      const textEl = root.querySelector('[data-bio-text]');
      const captionEl = root.querySelector('[data-bio-caption-text]');
      if (!textEl || !captionEl) return;

      const apiUrl = root.getAttribute('data-api-url');
      let currentLength = root.getAttribute('data-default-length');
      let currentModel = root.getAttribute('data-default-model');
      let currentVibe = root.getAttribute('data-default-vibe');

      // Tiny safe markdown+paragraph renderer for the model output. Some
      // models ignore "no markdown" and emit *italic* (this is intentional
      // for the wikipedia vibe — company names). Some return multi-paragraph
      // text with \n\n separators (wikipedia long, sci-fi long). Some return
      // line-broken verse (poem). We handle all three.
      function renderBio(text) {
        if (!text) return '';
        const escaped = String(text)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
        // Split into paragraphs on \n\n+.
        const paragraphs = escaped.split(/\n{2,}/);
        const rendered = paragraphs
          .map((p) =>
            p
              .replace(/\*\*([^*\n]+?)\*\*/g, '<strong>$1</strong>')
              .replace(/(^|[^*\w])\*([^*\n]+?)\*(?!\*|\w)/g, '$1<em>$2</em>')
              .replace(/\n/g, '<br>')
          )
          .map((p) => '<p>' + p + '</p>')
          .join('');
        return rendered;
      }

      const buttons = root.querySelectorAll('.bio-regen__option');
      const generateBtn = root.querySelector('[data-bio-generate]');
      let inFlightToken = 0;
      let hasGenerated = false;

      function setButtonStates(axis, value) {
        buttons.forEach((btn) => {
          if (btn.getAttribute('data-axis') !== axis) return;
          const isActive = btn.getAttribute('data-value') === value;
          btn.setAttribute('data-active', isActive ? 'true' : 'false');
          btn.setAttribute('aria-checked', isActive ? 'true' : 'false');
        });
      }

      function setDisabled(disabled) {
        buttons.forEach((btn) => {
          if (disabled) btn.setAttribute('disabled', 'true');
          else btn.removeAttribute('disabled');
        });
        if (generateBtn) {
          if (disabled) generateBtn.setAttribute('disabled', 'true');
          else generateBtn.removeAttribute('disabled');
        }
      }

      function setCaption(text, kind) {
        captionEl.textContent = text;
        captionEl.parentElement.setAttribute('data-state', kind);
      }

      async function regenerate() {
        const token = ++inFlightToken;
        const length = currentLength;
        const model = currentModel;
        const vibe = currentVibe;

        setCaption('Asking ' + model + '…', 'loading');
        textEl.classList.add('bio-regen__text--loading');
        setDisabled(true);

        try {
          const res = await fetch(apiUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ length: length, model: model, vibe: vibe }),
          });
          if (token !== inFlightToken) return;
          if (!res.ok) {
            const errData = await res.json().catch(() => ({}));
            throw new Error(errData.error || ('HTTP ' + res.status));
          }
          const data = await res.json();
          if (token !== inFlightToken) return;
          textEl.innerHTML = renderBio(data.text);
          resolveSweep(textEl);
          setCaption(
            'Generated by ' +
              model +
              (data.cached ? ' · cached' : ' · live') +
              ' · ' +
              length +
              ' · ' +
              vibe,
            'ok'
          );
        } catch (err) {
          if (token !== inFlightToken) return;
          const fallback = variants[length];
          if (fallback) {
            textEl.innerHTML = renderBio(fallback);
            resolveSweep(textEl);
          }
          setCaption(
            'Live generation failed (' +
              (err && err.message ? err.message : 'network error') +
              ') — showing fallback text.',
            'error'
          );
        } finally {
          if (token === inFlightToken) {
            textEl.classList.remove('bio-regen__text--loading');
            setDisabled(false);
          }
        }
      }

      // Dial clicks ONLY update the selection — no API call. This avoids
      // firing a generation on every parameter change (which would be 3
      // calls to set length + model + vibe). The user picks settings,
      // then hits Regenerate to fire a single call.
      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const axis = btn.getAttribute('data-axis');
          const value = btn.getAttribute('data-value');
          if (!axis || !value) return;
          if (axis === 'length') currentLength = value;
          else if (axis === 'model') currentModel = value;
          else if (axis === 'vibe') currentVibe = value;
          setButtonStates(axis, value);
          // Once the user has generated at least once, nudge them that the
          // current bio no longer matches the freshly-changed dials.
          if (hasGenerated) {
            setCaption('Settings changed — hit Regenerate to apply.', 'idle');
          }
        });
      });

      // The Regenerate button is the only thing that fires the API call.
      if (generateBtn) {
        generateBtn.addEventListener('click', () => {
          hasGenerated = true;
          regenerate();
        });
      }

      // First paint: resolve the pre-rendered fallback bio in. Wait for the
      // Redaction faces so the scramble actually shows (else it flashes the
      // serif fallback). document.fonts.ready resolves immediately if cached.
      const startSweep = () => resolveSweep(textEl);
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(startSweep);
      } else {
        startSweep();
      }
    });
  })();
</script>

<style is:global>
  /* ---------------------------------------------------------------- */
  /* BioRegenerator                                                   */
  /* ---------------------------------------------------------------- */

  .bio-regen {
    margin-top: var(--space-md);
  }

  .bio-regen__text {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 50ch;
    margin: 0;
    transition: opacity 0.18s ease;
  }

  /* Paragraph spacing inside the bio. Per-paragraph margin, not body
     default. Tight enough that wiki long stays readable on a card-ish
     viewport. */
  .bio-regen__text p {
    margin: 0 0 0.7em;
  }
  .bio-regen__text p:last-child {
    margin-bottom: 0;
  }

  .bio-regen__text em {
    font-style: italic;
  }

  .bio-regen__text strong {
    font-weight: 600;
  }

  .bio-regen__text--loading {
    opacity: 0.4;
  }

  /* Resolve-sweep word states. Words start as faint, blurred, accent-tinted
     Redaction "noise" and settle into the clean body font + text colour,
     left-to-right, so the bio reads as being generated. */
  .bio-word {
    transition: opacity 0.28s ease, filter 0.28s ease, color 0.28s ease;
  }
  .bio-word--scrambling {
    opacity: 0.5;
    filter: blur(1.4px);
    color: var(--color-accent);
  }
  .bio-word--resolved {
    opacity: 1;
    filter: none;
  }

  .bio-regen__controls {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: var(--space-md);
    margin-bottom: 0.6rem;
    max-width: 50ch;
  }

  .bio-regen__dial {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    column-gap: 0.9rem;
    align-items: baseline;
  }

  .bio-regen__dial-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    user-select: none;
  }

  .bio-regen__options {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.2;
    align-items: baseline;
  }

  .bio-regen__option {
    background: none;
    border: none;
    padding: 0.25rem 0.55rem;
    font: inherit;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: 0;
    transition: color 0.15s ease, opacity 0.15s ease;
    letter-spacing: 0.02em;
    position: relative;
  }

  .bio-regen__option + .bio-regen__option::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.3rem;
    bottom: 0.3rem;
    width: 1px;
    background: var(--color-rule);
  }

  .bio-regen__option:hover,
  .bio-regen__option:focus-visible {
    color: var(--color-text);
    outline: none;
  }

  .bio-regen__option[data-active='true'] {
    color: var(--color-accent);
  }

  .bio-regen__option[data-active='true']::after {
    content: '';
    position: absolute;
    left: 0.55rem;
    right: 0.55rem;
    bottom: 0.05rem;
    height: 1px;
    background: var(--color-accent);
  }

  .bio-regen__option[disabled] {
    opacity: 0.5;
    cursor: wait;
  }

  .bio-regen__action {
    margin-bottom: 0.6rem;
  }

  .bio-regen__generate {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-bg);
    background: var(--color-accent);
    border: none;
    padding: 0.45rem 1rem;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.15s ease, transform 0.1s ease;
  }

  .bio-regen__generate:hover,
  .bio-regen__generate:focus-visible {
    opacity: 0.88;
    outline: none;
  }

  .bio-regen__generate:active {
    transform: translateY(1px);
  }

  .bio-regen__generate[disabled] {
    opacity: 0.5;
    cursor: wait;
  }

  .bio-regen__caption {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    max-width: 50ch;
  }

  .bio-regen__caption-dot {
    color: var(--color-rule);
    font-size: 0.5rem;
    line-height: 1;
    transform: translateY(-0.15rem);
  }

  .bio-regen__caption[data-state='loading'] .bio-regen__caption-dot {
    color: var(--color-accent);
    animation: bio-regen-pulse 1.2s ease-in-out infinite;
  }

  .bio-regen__caption[data-state='ok'] .bio-regen__caption-dot {
    color: var(--color-accent);
  }

  .bio-regen__caption[data-state='error'] .bio-regen__caption-dot {
    color: #b8624c;
  }

  @keyframes bio-regen-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  @media (max-width: 50rem) {
    .bio-regen__dial {
      grid-template-columns: 1fr;
      row-gap: 0.15rem;
      margin-bottom: 0.5rem;
    }
  }
</style>
